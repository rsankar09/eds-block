{
  "definitions": [
    {
      "title": "Cards",
      "id": "cards",
      "model": "cards",
      "filter": "cards",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
                "name": "Cards",
                "model": "cards",
                "html": "<div class='cards'><ul>{{#each items}}<li>{{> card this.card}}</li>{{/each}}</ul></div>"
            }
          }
        },
        "da": {
          "rows": 1,
          "columns": 2
        }
      }
    },
    {
      "title": "Card",
      "id": "card",
      "model": "card",
      "plugins": {
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1)>picture>img[src]"},
            { "name": "imageAlt", "selector": "div:nth-child(1)>picture>img[alt]"},
            { "name": "text", "selector": "div:nth-child(2)" }
          ]
        },
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Card",
              "model": "card",
              "html": "<div class='cards-card-image'><img src='{{image}}' alt='{{imageAlt}}'></div><div class='cards-card-body'>{{{text}}}</div>"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "card",
      "fields": [
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "multi": false
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt",
          "multi": false
        },
        {
          "component": "richtext",
          "name": "text",
          "value": "",
          "label": "Text",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "cards",
      "components": [
        "card"
      ]
    }
  ]
}

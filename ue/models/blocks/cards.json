{
  "definitions": [
    {
      "title": "Cards",
      "id": "cards",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Cards",
              "model": "cards",
              "filter": "cards",
              "html": "<div class='cards'><ul>{{#each items}}<li>{{> card this}}</li>{{/each}}</ul></div>"
            }
          }
        },
        "da": {
          "rows": 1,
          "columns": 2
        }
      }
    },
    {
      "title": "Card",
      "id": "card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Card",
              "model": "card",
              "filter": "card",
              "html": "<div><picture><img src='{{image}}' alt='{{imageAlt}}'></picture></div><div>{{{text}}}</div>"
            }
          }
        },
        "da": {
          "rows": 1,
          "columns": 2,
          "fields": [
            { "name": "image", "selector": "div:nth-child(1) picture img[src]" },
            { "name": "imageAlt", "selector": "div:nth-child(1) picture img[alt]" },
            { "name": "text", "selector": "div:nth-child(2)" }
          ]
        }
      }
    }
  ],

  "models": [
    {
      "id": "cards",
      "fields": [
        {
          "component": "container",
          "name": "items",
          "label": "Cards",
          "multi": true,
          "valueType": "card"
        }
      ]
    },
    {
      "id": "card",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Image",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt",
          "valueType": "string"
        },
        {
          "component": "richtext",
          "name": "text",
          "label": "Text",
          "valueType": "string"
        }
      ]
    }
  ],

  "filters": [
    {
      "id": "cards",
      "components": ["card"]
    },
    {
      "id": "card",
      "components": []
    }
  ]
}
